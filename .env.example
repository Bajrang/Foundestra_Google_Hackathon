# Copy to .env and fill in your values. Never commit .env or service account JSON files.

GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=True
GOOGLE_GENAI_VERTEXAI_MODEL=gemini-2.5-flash
GOOGLE_GENAI_VERTEXAI_EMBEDDING_MODEL=textembedding-gecko-001

# Path to service account JSON (file must stay local; see .gitignore)
GOOGLE_APPLICATION_CREDENTIALS=google-hackathon-sa-key.json

# Alternative: inline service account JSON (do not commit)
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# Optional API keys (use one of service account or API key for Vertex AI)
# VERTEX_AI_API_KEY=your-vertex-ai-api-key
# GOOGLE_MAPS_API_KEY=your-google-maps-api-key

LOCAL_API_PORT=3001

# Frontend production build — Cloud Function API base (no trailing slash)
# VITE_API_BASE_URL=https://foundestra-travel-api-XXXX.us-central1.run.app/make-server-f7922768

# Supabase (production / remote API)
# SUPABASE_URL=your-supabase-url
# SUPABASE_ANON_KEY=your-supabase-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# OPENWEATHER_API_KEY=your-openweather-api-key